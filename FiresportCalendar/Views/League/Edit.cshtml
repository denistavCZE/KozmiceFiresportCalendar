@model FiresportCalendar.Models.League
@if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    <h2>Editace závodu</h2>

    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Color" class="control-label"></label>
            <select id="colorSelect" asp-for="Color"
                    class="form-control"
                    asp-items="Html.GetEnumSelectList<ColorEnum>()">
            </select>
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <input type="submit" value="Uložit" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Zrušit</a>
        </div>
    </form>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");

            <script>
                document.addEventListener("DOMContentLoaded", function () {
                    const select = document.getElementById("colorSelect");

                    Array.from(select.options).forEach(option => {
                        const text = option.text.toLowerCase();
                        const className = "bg-" + text;
                        option.classList.add(className);
                    });

                    function updateColor() {
                        const selectedText = select.options[select.selectedIndex].text.toLowerCase();

                        select.className = "form-control";
                        select.classList.add("bg-" + selectedText);
                    }

                    select.addEventListener("change", updateColor);

                    updateColor();
                });


            </script>
        }
    }
}
