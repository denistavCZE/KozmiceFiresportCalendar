@model FiresportCalendar.Models.Team
@if (User.Identity.IsAuthenticated && User.IsInRole("Admin"))
{
    <h2>Nový tým</h2>

    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="form-group">
            <label asp-for="Name" class="control-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Active" class="control-label"></label>
            <input asp-for="Active" class="form-check-input" type="checkbox" />
            <span asp-validation-for="Active" class="text-danger"></span>
        </div>

        <div class="form-group mt-2">
            <input type="submit" value="Uložit" class="btn btn-primary" />
            <a asp-action="Index" class="btn btn-secondary">Zrušit</a>
        </div>
    </form>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
    }
}
